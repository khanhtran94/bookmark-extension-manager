{
  "manifest_version": 3,
  "name": "Bookmark Manager",
  "version": "1.0.0",
  "description": "Quan ly bookmark don gian",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "manager.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bookmark Manager"
  }
}
